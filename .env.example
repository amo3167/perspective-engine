# Perspective Engine — Environment Variables
# Copy this file to .env and fill in your values.

# ── LLM Provider ──────────────────────────────────────────────
# Gemini (free tier — recommended for getting started)
GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI (optional)
# OPENAI_API_KEY=your-openai-api-key-here

# AWS Bedrock (optional — uses ~/.aws/credentials)
# AWS_DEFAULT_REGION=us-east-1

# ── Redis (optional — falls back to a file-backed store) ─────
# When Redis is unavailable, transcripts/context are persisted to a shared
# temp directory so the orchestrator and node subprocesses still see each other.
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=3
# PE_SHARED_MEM_DIR=/tmp/pe_shared_mem   # override the no-Redis fallback location

# ── TLS ──────────────────────────────────────────────────────
# Certificate verification for all LLM/credential traffic is ON by default.
# Only set this to false behind a trusted MITM proxy with a self-signed cert.
# LITELLM_SSL_VERIFY=true

# ── Standalone UI server (pe-server) ─────────────────────────
# PE_SERVER_PORT=8100
# PE_PUBLIC_URL=http://127.0.0.1:8100
# PERSPECTIVE_ENGINE_BACKEND_URL=http://127.0.0.1:8100

# ── Debate / Research Lab (paths under AutoBBS checkout) ─────
# When perspective-engine lives inside AutoBBS, parent repo is detected automatically.
# For a standalone clone, point at the repo that contains .agent/skills:
# AUTOBBS_ROOT=/path/to/AutoBBS

# Optional overrides for simulators posting events to pe-server:
# DEBATE_BROADCAST_URL=http://127.0.0.1:8100/api/monitor/debate/broadcast
# FEEDBACK_BROADCAST_URL=http://127.0.0.1:8100/api/monitor/feedback/broadcast
